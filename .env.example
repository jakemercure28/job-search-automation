# Copy to .env and fill in. Never commit .env.

# --- LLM providers ---
# Google AI Studio: https://aistudio.google.com/apikey (free tier: 500 RPD)
GEMINI_API_KEY=

# Optional: Sapling AI text detection (used in the voice-check pipeline)
# https://sapling.ai
SAPLING_API_KEY=

# --- Gmail rejection sync (optional) ---
# Requires an app-specific password: https://myaccount.google.com/apppasswords
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=

# --- Applicant identity (used by auto-apply and form-fill) ---
APPLICANT_FIRST_NAME=
APPLICANT_LAST_NAME=
APPLICANT_EMAIL=
APPLICANT_PHONE=
APPLICANT_LINKEDIN=
APPLICANT_GITHUB=
APPLICANT_CITY=
# Alias: APPLICANT_LOCATION works the same as APPLICANT_CITY
APPLICANT_LOCATION=
APPLICANT_CURRENT_COMPANY=

# Applicant seniority and experience (used for the market-research visualization)
# Valid values: junior, mid, senior, staff
APPLICANT_SENIORITY=mid
APPLICANT_YOE=4

# Optional: education (used for auto-filling Greenhouse education section)
APPLICANT_SCHOOL=
APPLICANT_FIELD_OF_STUDY=
APPLICANT_GRAD_YEAR=

# --- EEO demographic defaults (used only if auto-apply runs on Greenhouse) ---
# These all default to "decline to answer" if unset. Override only if you want
# specific values sent on every submission.
APPLICANT_EEO_GENDER=
APPLICANT_EEO_GENDER_IDENTITY=
APPLICANT_EEO_PRONOUNS=
APPLICANT_EEO_ORIENTATION=
APPLICANT_EEO_HISPANIC=
APPLICANT_EEO_RACE=
APPLICANT_EEO_VETERAN=
APPLICANT_EEO_DISABILITY=

# --- Pipeline config ---
# Active profile. The default 'example' ships with the repo.
# To use your own, copy profiles/example to profiles/<your-name> and change this.
JOB_PROFILE_DIR=profiles/example
JOB_DB_PATH=profiles/example/jobs.db

# Dashboard HTTP port
DASHBOARD_PORT=3131

# --- Location filter ---
# Comma-separated list of cities/regions to always allow. Empty = allow all.
# Example: LOCATION_FILTER=seattle,bellevue,redmond
LOCATION_FILTER=
# Comma-separated list of cities/regions to always drop. Empty = block none.
LOCATION_BLOCKLIST=

# --- Built In scraper ---
# Subdomain for the Built In regional site (e.g. 'seattle', 'nyc', 'austin').
# Default 'www' hits the nationwide site.
BUILTIN_SUBDOMAIN=www

# --- Auto-apply ---
AUTO_APPLY_ENABLED=false
AUTO_APPLY_DRY_RUN=true
AUTO_APPLY_DAILY_SUCCESS_LIMIT=3
# Comma-separated list of ATS platforms to skip in unattended mode.
# Ashby is blocked by default because repeated automated submits can trigger spam warnings.
AUTO_APPLY_PLATFORM_BLOCKLIST=ashby
