{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jakemercure/job-search-automation/.claude/hooks/auto-branch.sh",
            "timeout": 10,
            "statusMessage": "Checking branch..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jakemercure/job-search-automation/.claude/hooks/auto-pr.sh",
            "timeout": 30,
            "statusMessage": "Opening PR..."
          }
        ]
      }
    ]
  }
}
